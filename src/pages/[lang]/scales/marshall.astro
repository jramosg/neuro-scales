---
import Layout from '@layouts/Layout.astro'
import MarshallForm from '@components/MarshallForm.astro'
import {
  getStaticLangPaths,
  getLangFromUrl,
  useTranslations,
} from '@i18n/utils'
import { marshallIndex } from '@scales/marshall'

export function getStaticPaths() {
  return getStaticLangPaths()
}

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Layout title={t('marshall.title')} description={t('marshall.description')}>
  <div class='page'>
    <div class='page-header'>
      <a href={`/${lang}`} class='breadcrumb'>
        <svg
          width='14'
          height='14'
          viewBox='0 0 14 14'
          fill='none'
          stroke='currentColor'
          stroke-width='1.5'
          aria-hidden='true'
        >
          <path d='M9 2L4 7l5 5'></path>
        </svg>
        {t('nav.home')}
      </a>
      <div class='header-content'>
        <div class='scale-meta'>
          <span class='scale-tag'>{marshallIndex.badge}</span>
          <span class='scale-activities'>
            {lang === 'es' ? '6 grados (I–VI)' : '6 gradu (I–VI)'}
          </span>
          <span class='scale-range'>
            {lang === 'es' ? 'TCE · TAC craneal' : 'KTE · TAC kraneala'}
          </span>
        </div>
        <h1 class='page-title'>{t('marshall.title')}</h1>
        <p class='page-subtitle'>{t('marshall.subtitle')}</p>
      </div>
      <p class='instructions'>{t('marshall.instructions')}</p>
    </div>

    <MarshallForm />
  </div>
</Layout>

<style>
  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: var(--s6) 0;
  }

  .page-header {
    padding-bottom: var(--s7);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--s6);
    animation: fadeUp 400ms ease both;
  }

  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--s5);
    transition: color var(--transition-fast);
  }

  .breadcrumb:hover {
    color: var(--color-text);
  }

  .header-content {
    margin-bottom: var(--s4);
  }

  .scale-meta {
    display: flex;
    align-items: center;
    gap: var(--s3);
    margin-bottom: var(--s4);
    flex-wrap: wrap;
  }

  .scale-tag {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-accent-dim);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    border-radius: var(--radius-sm);
    padding: 2px 8px;
  }

  .scale-activities,
  .scale-range {
    font-size: 0.75rem;
    color: var(--color-text-dim);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    padding: 2px 8px;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: var(--color-text);
    margin: 0 0 var(--s3);
    line-height: 1.2;
  }

  .page-subtitle {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .instructions {
    font-size: 0.85rem;
    color: var(--color-text-dim);
    line-height: 1.6;
    padding: var(--s4);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border-subtle);
    border-left: 3px solid var(--color-teal);
    border-radius: var(--radius-md);
    margin: 0;
  }
</style>
