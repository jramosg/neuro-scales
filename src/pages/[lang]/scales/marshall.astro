---
import Layout from '@layouts/Layout.astro'
import MarshallForm from '@components/MarshallForm.astro'
import ScalePageHeader from '@components/ScalePageHeader.astro'
import {
  getStaticLangPaths,
  getLangFromUrl,
  useTranslations,
} from '@i18n/utils'
import { marshallIndex } from '@scales/marshall'

export function getStaticPaths() {
  return getStaticLangPaths()
}

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Layout title={t('marshall.title')} description={t('marshall.description')}>
  <ScalePageHeader
    lang={lang}
    homeLabel={t('nav.home')}
    badge={marshallIndex.badge}
    meta1={lang === 'es' ? '6 grados (I–VI)' : '6 gradu (I–VI)'}
    meta2={lang === 'es' ? 'TCE · TAC craneal' : 'KTE · TAC kraneala'}
    title={t('marshall.title')}
    subtitle={t('marshall.subtitle')}
    instructions={t('marshall.instructions')}
  />

  <MarshallForm />
</Layout>
