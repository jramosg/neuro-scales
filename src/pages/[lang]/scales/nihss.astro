---
import Layout from '../../../layouts/Layout.astro'
import NIHSSForm from '../../../components/NIHSSForm.astro'
import ScalePageHeader from '@components/ScalePageHeader.astro'
import {
  getStaticLangPaths,
  getLangFromUrl,
  useTranslations,
} from '../../../i18n/utils'
import { nihssIndex } from '../../../scales/nihss'

export function getStaticPaths() {
  return getStaticLangPaths()
}

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Layout title={t('nihss.title')} description={t('nihss.description')}>
  <ScalePageHeader
    lang={lang}
    homeLabel={t('nav.home')}
    badge='NIHSS'
    meta1={`${nihssIndex.activities.length} ${lang === 'es' ? 'ítems' : 'item'}`}
    meta2={lang === 'es' ? 'Puntuación 0–42' : 'Puntuazioa 0–42'}
    title={t('nihss.title')}
    subtitle={t('nihss.subtitle')}
    instructions={t('nihss.instructions')}
    variant='accent'
  />

  <NIHSSForm />
</Layout>
