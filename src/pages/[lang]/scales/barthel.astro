---
import Layout from '../../../layouts/Layout.astro'
import BarthelForm from '../../../components/BarthelForm.astro'
import ScalePageHeader from '@components/ScalePageHeader.astro'
import {
  getStaticLangPaths,
  getLangFromUrl,
  useTranslations,
} from '../../../i18n/utils'
import { barthelIndex } from '../../../scales/barthel'

export function getStaticPaths() {
  return getStaticLangPaths()
}

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Layout title={t('barthel.title')} description={t('barthel.description')}>
  <ScalePageHeader
    lang={lang}
    homeLabel={t('nav.home')}
    badge='ABVD'
    meta1={`${barthelIndex.activities.length} ${lang === 'es' ? 'actividades' : 'jarduera'}`}
    meta2={lang === 'es' ? 'Puntuación 0–100' : 'Puntuazioa 0–100'}
    title={t('barthel.title')}
    subtitle={t('barthel.subtitle')}
    instructions={t('barthel.instructions')}
    variant='teal'
  />

  <BarthelForm />
</Layout>
