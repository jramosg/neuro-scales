---
import Layout from '@layouts/Layout.astro'
import GCSForm from '@components/GCSForm.astro'
import ScalePageHeader from '@components/ScalePageHeader.astro'
import {
  getStaticLangPaths,
  getLangFromUrl,
  useTranslations,
} from '@i18n/utils'
import { gcsIndex } from '@scales/gcs'

export function getStaticPaths() {
  return getStaticLangPaths()
}

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Layout title={t('gcs.title')} description={t('gcs.description')}>
  <ScalePageHeader
    lang={lang}
    homeLabel={t('nav.home')}
    badge='GCS'
    meta1={`${gcsIndex.activities.length} ${lang === 'es' ? 'ítems' : 'item'}`}
    meta2={lang === 'es' ? 'Puntuación 3–15' : 'Puntuazioa 3–15'}
    title={t('gcs.title')}
    subtitle={t('gcs.subtitle')}
    instructions={t('gcs.instructions')}
  />

  <GCSForm />
</Layout>
