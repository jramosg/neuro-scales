---
import ArrowLeft from '@components/icons/ArrowLeft.astro'

interface Props {
  lang: string
  homeLabel: string
  badge: string
  meta1: string
  meta2: string
  title: string
  subtitle: string
  instructions: string
  variant?: 'default' | 'teal' | 'accent'
}

const {
  lang,
  homeLabel,
  badge,
  meta1,
  meta2,
  title,
  subtitle,
  instructions,
  variant = 'default',
} = Astro.props
---

<div class={`page-header page-header--${variant}`}>
  <a href={`/${lang}`} class='breadcrumb'>
    <ArrowLeft width='14' height='14' />
    {homeLabel}
  </a>
  <div class='header-content'>
    <div class='scale-meta'>
      <span class='scale-tag'>{badge}</span>
      <span class='scale-activities'>{meta1}</span>
      <span class='scale-range'>{meta2}</span>
    </div>
    <h1 class='page-title'>{title}</h1>
    <p class='page-subtitle'>{subtitle}</p>
  </div>
  <p class='instructions'>{instructions}</p>
</div>

<style>
  .page-header {
    padding-bottom: var(--s7);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--s6);
    animation: fadeUp 400ms ease both;
  }

  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--s5);
    transition: color var(--transition-fast);
  }

  .breadcrumb:hover {
    color: var(--color-text);
  }

  .header-content {
    margin-bottom: var(--s4);
  }

  .scale-meta {
    display: flex;
    align-items: center;
    gap: var(--s3);
    margin-bottom: var(--s4);
    flex-wrap: wrap;
  }

  /* ── Shared: scale-tag base ────────────────────────────── */
  .scale-tag {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    padding: 2px 8px;
  }

  /* ── Shared: teal + accent meta separators ──────────────── */
  .page-header--teal .scale-activities,
  .page-header--teal .scale-range,
  .page-header--accent .scale-activities,
  .page-header--accent .scale-range {
    font-size: 0.775rem;
    color: var(--color-text-dim);
    letter-spacing: 0.01em;
  }

  .page-header--teal .scale-activities::before,
  .page-header--teal .scale-range::before,
  .page-header--accent .scale-activities::before,
  .page-header--accent .scale-range::before {
    content: '·';
    margin-right: var(--s3);
    color: var(--color-text-dim);
  }

  /* ── Shared: teal + accent page title ───────────────────── */
  .page-header--teal .page-title,
  .page-header--accent .page-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--color-text);
    margin-bottom: var(--s2);
  }

  /* ── Shared: teal + accent page subtitle ────────────────── */
  .page-header--teal .page-subtitle,
  .page-header--accent .page-subtitle {
    font-size: 0.95rem;
    font-weight: 500;
  }

  /* ── Shared: teal + accent instructions base ────────────── */
  .page-header--teal .instructions,
  .page-header--accent .instructions {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    padding: var(--s4);
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  /* ── Default variant (fisher / gcs / marshall) ─────────── */
  .page-header--default .scale-tag {
    color: var(--color-accent);
    background: var(--color-accent-dim);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
  }

  .page-header--default .scale-activities,
  .page-header--default .scale-range {
    font-size: 0.75rem;
    color: var(--color-text-dim);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    padding: 2px 8px;
  }

  .page-header--default .page-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: var(--color-text);
    margin: 0 0 var(--s3);
    line-height: 1.2;
  }

  .page-header--default .page-subtitle {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .page-header--default .instructions {
    font-size: 0.85rem;
    color: var(--color-text-dim);
    line-height: 1.6;
    padding: var(--s4);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border-subtle);
    border-left: 3px solid var(--color-teal);
    border-radius: var(--radius-md);
    margin: 0;
  }

  /* ── Teal variant (barthel) ────────────────────────────── */
  .page-header--teal .scale-tag {
    color: var(--color-teal-light);
    background: var(--color-teal-dim);
    border: 1px solid rgba(74, 173, 173, 0.2);
  }

  .page-header--teal .page-subtitle {
    color: var(--color-teal-light);
  }

  .page-header--teal .instructions {
    border-left: 3px solid var(--color-teal);
  }

  /* ── Accent variant (nihss) ────────────────────────────── */
  .page-header--accent .scale-tag {
    color: var(--color-accent-light);
    background: var(--color-accent-dim);
    border: 1px solid rgba(212, 145, 58, 0.2);
    padding: 2px 7px;
  }

  .page-header--accent .page-subtitle {
    color: var(--color-accent-light);
  }

  .page-header--accent .instructions {
    border-left: 3px solid var(--color-accent);
  }
</style>
