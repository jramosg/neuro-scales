---
import { getLangFromUrl, useTranslations, getLanguageUrls } from '../i18n/utils'
import ThemeToggle from './ThemeToggle.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const langUrls = getLanguageUrls(Astro.url)

const langLabels: Record<string, { code: string; native: string }> = {
  es: { code: 'ES', native: 'Castellano' },
  eu: { code: 'EU', native: 'Euskara' },
  en: { code: 'EN', native: 'English' },
}
---

<header>
  <div class='container'>
    <a href={`/${lang}`} class='logo' aria-label={t('nav.home')}>
      <span class='logo-icon' aria-hidden='true'>
        <svg
          width='22'
          height='22'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='1.5'
        >
          <path
            d='M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z'
          ></path>
          <path d='M8 12c0-2.21 1.79-4 4-4s4 1.79 4 4-1.79 4-4 4-4-1.79-4-4z'
          ></path>
          <path d='M12 8v-2M12 18v-2M8 12H6M18 12h-2'></path>
        </svg>
      </span>
      <span class='logo-text'>NeuroEskalak</span>
    </a>

    <nav aria-label='Principal'>
      <a href={`/${lang}`} class='nav-link'>{t('nav.home')}</a>
    </nav>

    <div class='controls'>
      <ThemeToggle />

      <div class='lang-switcher' role='navigation' aria-label='Language'>
        {
          (['es', 'eu', 'en'] as const).map((l) => (
            <a
              href={langUrls[l]}
              class:list={['lang-pill', { active: l === lang }]}
              aria-current={l === lang ? 'page' : undefined}
              aria-label={langLabels[l].native}
            >
              {langLabels[l].code}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 64px;
    background: var(--color-header-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition:
      background-color var(--transition-theme),
      border-color var(--transition-theme);
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 var(--s5);
    height: 100%;
    display: flex;
    align-items: center;
    gap: var(--s5);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--s2);
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: 1.1rem;
    letter-spacing: -0.01em;
    text-decoration: none;
    flex-shrink: 0;
    transition: color var(--transition-fast);
  }

  .logo:hover {
    color: var(--color-accent-light);
  }

  .logo-icon {
    display: flex;
    align-items: center;
    color: var(--color-teal);
    transition: color var(--transition-fast);
  }

  .logo:hover .logo-icon {
    color: var(--color-teal-light);
  }

  nav {
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--s4);
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
    transition: color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .controls {
    display: flex;
    align-items: center;
    gap: var(--s2);
    flex-wrap: nowrap;
  }

  .lang-switcher {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    flex-shrink: 0;
    height: 30px;
    transition: border-color var(--transition-fast);
  }

  .lang-switcher:hover {
    border-color: var(--color-teal);
  }

  .lang-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 8px;
    height: 100%;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    background: transparent;
    transition: all var(--transition-fast);
    border-right: 1px solid var(--color-border);
    white-space: nowrap;
  }

  .lang-pill:last-child {
    border-right: none;
  }

  .lang-pill:hover:not(.active) {
    color: var(--color-teal-light);
    background: var(--color-teal-dim);
  }

  .lang-pill.active {
    background: var(--color-teal);
    color: var(--color-on-primary);
    cursor: default;
  }
</style>
