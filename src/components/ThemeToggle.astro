---
import { useTranslations, getLangFromUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label={t('theme.toggle')}
  title={t('theme.toggle')}
>
  <!-- Sun icon (shown in dark mode) -->
  <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    function getCurrentTheme(): string {
      return document.documentElement.getAttribute('data-theme') ?? 'light';
    }

    function setTheme(theme: string) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      btn.setAttribute('data-current', theme);
    }

    // Set initial icon state
    btn.setAttribute('data-current', getCurrentTheme());

    btn.addEventListener('click', () => {
      const next = getCurrentTheme() === 'dark' ? 'light' : 'dark';
      setTheme(next);
    });
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
    flex-shrink: 0;
    position: relative;
  }

  .theme-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  /* Icon visibility based on current theme */
  .icon-sun,
  .icon-moon {
    position: absolute;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  /* Light mode: show moon, hide sun */
  :root:not([data-theme='dark']) .icon-sun,
  [data-theme='light'] .icon-sun {
    opacity: 0;
    transform: rotate(90deg) scale(0.7);
  }

  :root:not([data-theme='dark']) .icon-moon,
  [data-theme='light'] .icon-moon {
    opacity: 1;
    transform: none;
  }

  /* Dark mode: show sun, hide moon */
  [data-theme='dark'] .icon-sun {
    opacity: 1;
    transform: none;
  }

  [data-theme='dark'] .icon-moon {
    opacity: 0;
    transform: rotate(-90deg) scale(0.7);
  }
</style>
