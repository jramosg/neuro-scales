---
export interface LevelInfo {
  key: string;
  label: string;
  desc: string;
  colorIndex: 0 | 1 | 2 | 3 | 4;
}

export interface Zone {
  from: number;
  to: number;
  colorIndex: 0 | 1 | 2 | 3 | 4;
  label: string;
}

interface Props {
  maxScore: number;
  maxLabel: string;
  scoreLabel: string;
  interpretationTitle: string;
  rangesTitle: string;
  retakeLabel: string;
  backHref: string;
  backLabel: string;
  levels: LevelInfo[];
  zones: Zone[];
  gaugeMarks: number[];
}

const {
  maxScore, maxLabel, scoreLabel, interpretationTitle,
  rangesTitle, retakeLabel, backHref, backLabel,
  levels, zones, gaugeMarks,
} = Astro.props;

// Build levels lookup keyed by level key
const levelsMap = Object.fromEntries(
  levels.map((l) => [l.key, { label: l.label, desc: l.desc, colorIndex: l.colorIndex }])
);
---

<div
  id="results-card"
  class="results-card"
  hidden
  aria-live="polite"
  data-levels={JSON.stringify(levelsMap)}
  data-max-score={String(maxScore)}
>
  <div class="results-inner">
    <!-- Header: score + level -->
    <div class="results-header">
      <div id="result-level-block" class="level-block">
        <span id="score-value" class="score-value">—</span>
        <span class="score-max">{maxLabel}</span>
      </div>
      <div class="level-text">
        <p class="score-label">{scoreLabel}</p>
        <p id="level-label" class="level-label"></p>
      </div>
    </div>

    <!-- Gauge with coloured zone bands -->
    <div
      class="gauge-wrap"
      id="gauge-wrap"
      role="meter"
      aria-valuemin="0"
      aria-valuemax={maxScore}
    >
      <div class="gauge-track">
        <!-- Static zone bands -->
        {zones.map((zone) => {
          const left = (zone.from / maxScore) * 100;
          const width = Math.max(((zone.to - zone.from + 1) / maxScore) * 100, 1.5);
          return (
            <div
              class={`gauge-zone ci-${zone.colorIndex}`}
              style={`left:${left}%;width:${width}%`}
              title={zone.label}
            />
          );
        })}
        <!-- Animated marker -->
        <div class="gauge-marker" id="gauge-marker" style="left:0%">
          <span class="gauge-marker-value" id="gauge-marker-value">0</span>
        </div>
      </div>
      <div class="gauge-marks">
        {gaugeMarks.map((mark) => (
          <span
            class="gauge-mark"
            style={`left:${(mark / maxScore) * 100}%`}
          >
            {mark}
          </span>
        ))}
      </div>
    </div>

    <!-- Interpretation -->
    <div class="interpretation">
      <p class="interpretation-title">{interpretationTitle}</p>
      <p id="interpretation-text" class="interpretation-text"></p>
    </div>

    <!-- Scale reference ranges -->
    <details class="scale-ranges">
      <summary>{rangesTitle}</summary>
      <ul>
        {levels.map((l) => (
          <li class={`ci-${l.colorIndex}`}>{l.label}</li>
        ))}
      </ul>
    </details>

    <!-- Actions -->
    <div class="results-actions">
      <button type="button" id="retake-btn" class="btn-retake">
        {retakeLabel}
      </button>
      <a href={backHref} class="btn-back">
        {backLabel}
      </a>
    </div>
  </div>
</div>

<script>
  function initResultsCard() {
    const card = document.getElementById('results-card') as HTMLElement | null;
    if (!card) return;

    // Listen for result events from any scale form
    document.addEventListener('scale:result', (e) => {
      const { score, level } = (e as CustomEvent<{ score: number; level: string }>).detail;
      const levelsData = JSON.parse(card.dataset.levels || '{}') as Record<
        string,
        { label: string; desc: string; colorIndex: number }
      >;
      const maxScore = Number(card.dataset.maxScore || 100);
      const info = levelsData[level] ?? { label: level, desc: '', colorIndex: 2 };

      const scoreEl   = document.getElementById('score-value')!;
      const markerVal = document.getElementById('gauge-marker-value')!;
      const levelBlock = document.getElementById('result-level-block')!;
      const levelLabel = document.getElementById('level-label')!;
      const interpText = document.getElementById('interpretation-text')!;
      const marker     = document.getElementById('gauge-marker')!;
      const gaugeWrap  = document.getElementById('gauge-wrap')!;

      scoreEl.textContent   = String(score);
      markerVal.textContent = String(score);
      levelLabel.textContent = info.label;
      interpText.textContent = info.desc;

      // Apply level colour
      levelBlock.className = `level-block ci-${info.colorIndex}`;
      levelLabel.className = `level-label ci-${info.colorIndex}`;

      // Animate marker
      const pct = (score / maxScore) * 100;
      // small delay so CSS transition fires after unhide
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          marker.style.left = `${pct}%`;
        });
      });
      gaugeWrap.setAttribute('aria-valuenow', String(score));

      // Show card with animation
      card.hidden = false;
      card.querySelector('.results-inner')!.classList.add('animate-in');
      card.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // Retake button → tell the form to reset
    document.getElementById('retake-btn')?.addEventListener('click', () => {
      card.hidden = true;
      card.querySelector('.results-inner')?.classList.remove('animate-in');
      document.dispatchEvent(new CustomEvent('scale:retake'));
    });
  }

  initResultsCard();
  document.addEventListener('astro:after-swap', initResultsCard);
</script>

<style>
  .results-card {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--s6) 0 var(--s10);
  }

  .results-inner {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    overflow: hidden;
    transition: background-color var(--transition-theme), border-color var(--transition-theme);
  }

  .results-inner.animate-in {
    animation: scaleIn 400ms ease both;
  }

  /* ── Header ── */
  .results-header {
    padding: var(--s7) var(--s7) var(--s6);
    background: linear-gradient(160deg, var(--color-surface-raised) 0%, var(--color-surface) 100%);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: var(--s6);
    transition: background var(--transition-theme);
  }

  .level-block {
    flex-shrink: 0;
    text-align: center;
    transition: --level-color var(--transition-med);
  }

  .score-value {
    display: block;
    font-family: var(--font-serif);
    font-size: 4rem;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--level-color, var(--color-text-muted));
    transition: color var(--transition-med);
  }

  .score-max {
    font-size: 0.75rem;
    color: var(--color-text-dim);
    display: block;
    margin-top: var(--s1);
  }

  .score-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--s2);
  }

  .level-label {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    letter-spacing: -0.02em;
    color: var(--level-color, var(--color-text-muted));
    transition: color var(--transition-med);
  }

  /* ── Gauge ── */
  .gauge-wrap {
    padding: var(--s5) var(--s7) var(--s5);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .gauge-track {
    position: relative;
    height: 12px;
    background: var(--color-border);
    border-radius: 99px;
    overflow: visible;
    margin-bottom: var(--s5);
  }

  /* Zone bands */
  .gauge-zone {
    position: absolute;
    top: 0;
    height: 100%;
    background: var(--level-color, var(--color-border));
    opacity: 0.35;
    border-radius: 0;
    transition: opacity var(--transition-fast);
  }

  /* Round the outer edges */
  .gauge-zone:first-child  { border-radius: 99px 0 0 99px; }
  .gauge-zone:last-of-type { border-radius: 0 99px 99px 0; }

  [data-theme='dark'] .gauge-zone { opacity: 0.45; }

  /* Animated position marker */
  .gauge-marker {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    transition: left 700ms cubic-bezier(0.34, 1.4, 0.64, 1);
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
    z-index: 2;
  }

  .gauge-marker::before {
    content: '';
    width: 16px;
    height: 16px;
    background: var(--color-text);
    border: 2.5px solid var(--color-bg);
    border-radius: 50%;
    box-shadow: 0 0 0 2px var(--color-text);
    display: block;
    transition: background-color var(--transition-theme), border-color var(--transition-theme);
  }

  .gauge-marker-value {
    position: absolute;
    top: 18px;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* Axis marks */
  .gauge-marks {
    position: relative;
    height: 18px;
  }

  .gauge-mark {
    position: absolute;
    transform: translateX(-50%);
    font-size: 0.68rem;
    color: var(--color-text-dim);
    top: 0;
    white-space: nowrap;
  }

  /* ── Interpretation ── */
  .interpretation {
    padding: var(--s5) var(--s7);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .interpretation-title {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: var(--s2);
  }

  .interpretation-text {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    min-height: 1.5em;
  }

  /* ── Scale ranges ── */
  .scale-ranges {
    padding: var(--s3) var(--s7);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .scale-ranges summary {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-dim);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--s2);
    padding: var(--s2) 0;
    user-select: none;
  }

  .scale-ranges summary::before {
    content: '▸';
    font-size: 0.6rem;
    transition: transform var(--transition-fast);
  }

  .scale-ranges[open] summary::before { transform: rotate(90deg); }

  .scale-ranges ul {
    margin-top: var(--s2);
    margin-bottom: var(--s3);
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--s2);
  }

  .scale-ranges li {
    font-size: 0.825rem;
    padding-left: var(--s5);
    position: relative;
    color: var(--level-color, var(--color-text-muted));
  }

  .scale-ranges li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--level-color, var(--color-text-dim));
  }

  /* ── Actions ── */
  .results-actions {
    padding: var(--s5) var(--s7);
    display: flex;
    gap: var(--s3);
    flex-wrap: wrap;
  }

  .btn-retake {
    padding: var(--s3) var(--s5);
    background: var(--color-surface-raised);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .btn-retake:hover {
    border-color: var(--color-text-muted);
    background: var(--color-surface-hover);
  }

  .btn-back {
    padding: var(--s3) var(--s5);
    background: transparent;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .btn-back:hover {
    color: var(--color-text);
    border-color: var(--color-border);
  }

  @media (max-width: 480px) {
    .results-header { flex-direction: column; align-items: flex-start; gap: var(--s3); }
    .score-value { font-size: 3rem; }
  }
</style>
