---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="left">
      <span class="brand">{t('footer.credits')}</span>
      <span class="sep" aria-hidden="true">·</span>
      <span class="disclaimer">{t('footer.disclaimer')}</span>
    </div>
    <span class="year">{year}</span>
  </div>
</footer>

<style>
  footer {
    height: 80px;
    border-top: 1px solid var(--color-border-subtle);
    display: flex;
    align-items: center;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 var(--s5);
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s4);
  }

  .left {
    display: flex;
    align-items: center;
    gap: var(--s3);
    flex-wrap: wrap;
  }

  .brand {
    font-family: var(--font-serif);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    letter-spacing: -0.01em;
  }

  .sep {
    color: var(--color-text-dim);
    font-size: 0.75rem;
  }

  .disclaimer {
    font-size: 0.75rem;
    color: var(--color-text-dim);
    font-style: italic;
  }

  .year {
    font-size: 0.75rem;
    color: var(--color-text-dim);
    flex-shrink: 0;
  }

  @media (max-width: 500px) {
    .disclaimer {
      display: none;
    }
  }
</style>
