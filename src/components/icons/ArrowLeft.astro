---
interface Props {
  width?: string | number
  height?: string | number
  ariaLabel?: string
  ariaHidden?: boolean
  class?: string
}

const {
  width = '14',
  height = '14',
  ariaLabel,
  ariaHidden = true,
  class: className = '',
} = Astro.props
---

<svg
  width={width}
  height={height}
  viewBox='0 0 14 14'
  fill='none'
  stroke='currentColor'
  stroke-width='1.5'
  aria-label={ariaLabel}
  aria-hidden={ariaHidden}
  class={className}
>
  <path d='M9 2L4 7l5 5'></path>
</svg>
