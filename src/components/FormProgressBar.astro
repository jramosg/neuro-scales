---
interface Props {
  countId: string
  fillId: string
  label: string
}

const { countId, fillId, label } = Astro.props
---

<div class='progress-bar-wrap'>
  <p class='progress-info'>
    <span id={countId}>0</span>&nbsp;{label}
  </p>
  <div class='progress-track'>
    <div class='progress-fill' id={fillId} style='width:0%'></div>
  </div>
</div>

<style>
  .progress-bar-wrap {
    position: sticky;
    top: 64px;
    z-index: 50;
    background: var(--color-header-bg);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border-subtle);
    padding: var(--s3) 0;
    margin-bottom: var(--s7);
    display: flex;
    align-items: center;
    gap: var(--s4);
    transition: background var(--transition-theme);
  }

  .progress-info {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .progress-track {
    flex: 1;
    height: 3px;
    background: var(--color-border);
    border-radius: 99px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-teal), var(--color-accent));
    border-radius: 99px;
    transition: width var(--transition-med);
  }
</style>
